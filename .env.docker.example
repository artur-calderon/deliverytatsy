# Copie para .env.docker e ajuste antes de subir na VPS:
#   cp .env.docker.example .env.docker

APP_NAME=TastyIgniter
APP_ENV=production
APP_DEBUG=false
APP_URL=https://lanchonete.freddns.org

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tastyigniter
DB_USERNAME=tasty
DB_PASSWORD=troque_esta_senha
DB_PREFIX=ti_

MYSQL_ROOT_PASSWORD=troque_root_tambem

CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file

# Traefik — ajuste se os nomes na sua VPS forem diferentes
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_ENTRYPOINT_HTTPS=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# true = nao roda igniter:install no boot do container app
SKIP_INSTALL=false
